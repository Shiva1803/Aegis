# ── GitHub App credentials ──────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_INSTALLATION_ID=12345678

# ── LLM configuration ──────────────────────────────────────────
# Supported providers: anthropic, openai, groq, gemini
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-20250514

# Provider-specific model examples:
#   anthropic  → claude-sonnet-4-20250514
#   openai     → gpt-4o
#   groq       → llama-3.3-70b-versatile, mixtral-8x7b-32768
#   gemini     → gemini-2.5-flash, gemini-2.5-pro

# ── Key Roulette (optional) ────────────────────────────────────
# Enable round-robin rotation across multiple API keys.
# Useful for distributing rate limits across keys.
KEY_ROULETTE_ENABLED=false
# To use roulette, set multiple comma-separated keys:
#   LLM_API_KEY=sk-key1,sk-key2,sk-key3

# ── Guardrails ──────────────────────────────────────────────────
DIFF_TOKEN_LIMIT=8000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REVIEWS=3

# ── Dashboard / OAuth (optional) ────────────────────────────────
# GitHub OAuth App credentials (for dashboard login)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/auth/github/callback

# Comma-separated GitHub usernames who get admin role on dashboard
DASHBOARD_ADMIN_USERS=shiva1803

# Frontend URL for OAuth redirects and CORS
# Local dev: http://127.0.0.1:5173
# Production (Railway monolith): same as backend URL
FRONTEND_URL=http://127.0.0.1:5173
